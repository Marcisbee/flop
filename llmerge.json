{
  "entry": [
    "ts/mod.ts",
    "ts/client.ts"
  ],
  "lsp": {
    "deno": {
      "command": [
        "deno",
        "lsp"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "test": {
    "deno": {
      "command": [
        "deno",
        "test",
        "--allow-read",
        "--allow-write",
        "--allow-net",
        "--allow-env"
      ],
      "extensions": [
        "_test.ts",
        ".test.ts"
      ]
    }
  },
  "setup": {
    "commands": [
      "deno cache ts/mod.ts ts/client.ts ts/cli.ts"
    ]
  },
  "dev": {
    "processes": [
      {
        "id": "server",
        "command": "deno run --watch --allow-read --allow-write --allow-net --allow-env ts/cli.ts examples/messages/app.ts",
        "port": 1985,
        "tunnel": true
      }
    ]
  }
}

{
  "entry": [
    "go/flop.go"
  ],
  "lsp": {
    "deno": {
      "command": [
        "deno",
        "lsp"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "test": {
    "deno": {
      "command": [
        "deno",
        "test",
        "--allow-read",
        "--allow-write",
        "--allow-net",
        "--allow-env"
      ],
      "extensions": [
        "_test.ts",
        ".test.ts"
      ]
    }
  },
  "setup": {
    "commands": [
      "cd go && go test ./..."
    ]
  },
  "dev": {
    "processes": [
      {
        "id": "server",
        "command": "make -C examples/blog-go-react dev",
        "port": 1985,
        "tunnel": true
      }
    ]
  }
}

{
  "config": {
    "dataDir": "./data",
    "syncMode": "normal"
  },
  "tables": [
    {
      "name": "comments",
      "rowType": "Comment",
      "rowTs": "{ authorId: string; body: string; createdAt?: number; id?: string; postId: string }",
      "fields": [
        {
          "goName": "AuthorID",
          "jsonName": "authorId",
          "kind": "refSingle",
          "tsType": "string",
          "required": true,
          "indexed": true,
          "refTable": "users",
          "refField": "id"
        },
        {
          "goName": "Body",
          "jsonName": "body",
          "kind": "string",
          "tsType": "string",
          "required": true
        },
        {
          "goName": "CreatedAt",
          "jsonName": "createdAt",
          "kind": "timestamp",
          "tsType": "number",
          "default": "now"
        },
        {
          "goName": "ID",
          "jsonName": "id",
          "kind": "string",
          "tsType": "string",
          "primary": true,
          "primaryStrategy": "uuidv7"
        },
        {
          "goName": "PostID",
          "jsonName": "postId",
          "kind": "refSingle",
          "tsType": "string",
          "required": true,
          "indexed": true,
          "refTable": "posts",
          "refField": "id"
        }
      ]
    },
    {
      "name": "posts",
      "rowType": "Post",
      "rowTs": "{ authorId: string; body: string; coverImage?: { path: string; url: string; mime: string; size: number }; createdAt?: number; excerpt?: string; id?: string; internalNotes?: string; published?: boolean; publishedAt?: number; slug: string; title: string }",
      "fields": [
        {
          "goName": "AuthorID",
          "jsonName": "authorId",
          "kind": "refSingle",
          "tsType": "string",
          "required": true,
          "indexed": true,
          "refTable": "users",
          "refField": "id"
        },
        {
          "goName": "Body",
          "jsonName": "body",
          "kind": "string",
          "tsType": "string",
          "required": true
        },
        {
          "goName": "CoverImage",
          "jsonName": "coverImage",
          "kind": "fileSingle",
          "tsType": "{ path: string; url: string; mime: string; size: number }",
          "mimeTypes": [
            "image/*"
          ]
        },
        {
          "goName": "CreatedAt",
          "jsonName": "createdAt",
          "kind": "timestamp",
          "tsType": "number",
          "default": "now"
        },
        {
          "goName": "Excerpt",
          "jsonName": "excerpt",
          "kind": "string",
          "tsType": "string"
        },
        {
          "goName": "ID",
          "jsonName": "id",
          "kind": "string",
          "tsType": "string",
          "primary": true,
          "primaryStrategy": "uuidv7"
        },
        {
          "goName": "InternalNotes",
          "jsonName": "internalNotes",
          "kind": "string",
          "tsType": "string"
        },
        {
          "goName": "Published",
          "jsonName": "published",
          "kind": "boolean",
          "tsType": "boolean",
          "default": false
        },
        {
          "goName": "PublishedAt",
          "jsonName": "publishedAt",
          "kind": "timestamp",
          "tsType": "number"
        },
        {
          "goName": "Slug",
          "jsonName": "slug",
          "kind": "string",
          "tsType": "string",
          "required": true,
          "unique": true
        },
        {
          "goName": "Title",
          "jsonName": "title",
          "kind": "string",
          "tsType": "string",
          "required": true
        }
      ]
    },
    {
      "name": "secrets",
      "rowType": "Secret",
      "rowTs": "{ id?: string; key: string; value: string }",
      "fields": [
        {
          "goName": "ID",
          "jsonName": "id",
          "kind": "string",
          "tsType": "string",
          "primary": true,
          "primaryStrategy": "uuidv7"
        },
        {
          "goName": "Key",
          "jsonName": "key",
          "kind": "string",
          "tsType": "string",
          "required": true,
          "unique": true
        },
        {
          "goName": "Value",
          "jsonName": "value",
          "kind": "string",
          "tsType": "string",
          "required": true
        }
      ]
    },
    {
      "name": "users",
      "rowType": "User",
      "rowTs": "{ email: string; id?: string; name: string; password: string; roles?: (string)[] }",
      "fields": [
        {
          "goName": "Email",
          "jsonName": "email",
          "kind": "string",
          "tsType": "string",
          "required": true,
          "unique": true,
          "maxLen": 255,
          "format": "email"
        },
        {
          "goName": "ID",
          "jsonName": "id",
          "kind": "string",
          "tsType": "string",
          "primary": true,
          "primaryStrategy": "uuidv7"
        },
        {
          "goName": "Name",
          "jsonName": "name",
          "kind": "string",
          "tsType": "string",
          "required": true,
          "minLen": 2,
          "maxLen": 80
        },
        {
          "goName": "Password",
          "jsonName": "password",
          "kind": "bcrypt",
          "tsType": "string",
          "required": true,
          "bcryptRounds": 10
        },
        {
          "goName": "Roles",
          "jsonName": "roles",
          "kind": "roles",
          "tsType": "(string)[]",
          "default": []
        }
      ]
    }
  ],
  "views": [
    {
      "name": "get_comments",
      "access": {
        "type": "public"
      },
      "inputTs": "{ postId: string }",
      "outputTs": "(Record\u003cstring, any\u003e)[]"
    },
    {
      "name": "get_post",
      "access": {
        "type": "public"
      },
      "inputTs": "{ slug: string }",
      "outputTs": "Record\u003cstring, any\u003e"
    },
    {
      "name": "list_posts",
      "access": {
        "type": "public"
      },
      "inputTs": "{  }",
      "outputTs": "(Record\u003cstring, any\u003e)[]"
    }
  ],
  "reducers": [
    {
      "name": "add_comment",
      "access": {
        "type": "authenticated"
      },
      "inputTs": "{ body: string; postId: string }",
      "outputTs": "Record\u003cstring, any\u003e"
    },
    {
      "name": "create_post",
      "access": {
        "type": "authenticated"
      },
      "inputTs": "{ body: string; coverImage: string; excerpt: string; slug: string; title: string }",
      "outputTs": "Record\u003cstring, any\u003e"
    },
    {
      "name": "delete_post",
      "access": {
        "type": "authenticated"
      },
      "inputTs": "{ id: string }",
      "outputTs": "Record\u003cstring, any\u003e"
    },
    {
      "name": "update_post",
      "access": {
        "type": "authenticated"
      },
      "inputTs": "{ body: string; excerpt: string; id: string; title: string }",
      "outputTs": "Record\u003cstring, any\u003e"
    }
  ],
  "layouts": [],
  "pages": []
}
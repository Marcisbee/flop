{
  "config": {
    "dataDir": "./data",
    "syncMode": "normal"
  },
  "tables": [
    {
      "name": "movies",
      "rowType": "Movie",
      "rowTs": "{ createdAt?: number; genres?: (string)[]; id?: string; overview?: string; rating?: number; runtimeMinutes?: number; slug: string; title: string; votes?: number; year: number }",
      "fields": [
        {
          "goName": "CreatedAt",
          "jsonName": "createdAt",
          "kind": "timestamp",
          "tsType": "number",
          "default": "now"
        },
        {
          "goName": "Genres",
          "jsonName": "genres",
          "kind": "set",
          "tsType": "(string)[]",
          "default": []
        },
        {
          "goName": "ID",
          "jsonName": "id",
          "kind": "string",
          "tsType": "string",
          "primary": true,
          "autogen": "[a-z0-9]{12}"
        },
        {
          "goName": "Overview",
          "jsonName": "overview",
          "kind": "string",
          "tsType": "string"
        },
        {
          "goName": "Rating",
          "jsonName": "rating",
          "kind": "number",
          "tsType": "number"
        },
        {
          "goName": "RuntimeMinutes",
          "jsonName": "runtimeMinutes",
          "kind": "integer",
          "tsType": "number"
        },
        {
          "goName": "Slug",
          "jsonName": "slug",
          "kind": "string",
          "tsType": "string",
          "required": true,
          "unique": true
        },
        {
          "goName": "Title",
          "jsonName": "title",
          "kind": "string",
          "tsType": "string",
          "required": true
        },
        {
          "goName": "Votes",
          "jsonName": "votes",
          "kind": "integer",
          "tsType": "number"
        },
        {
          "goName": "Year",
          "jsonName": "year",
          "kind": "integer",
          "tsType": "number",
          "required": true
        }
      ]
    }
  ],
  "views": [],
  "reducers": [],
  "layouts": [],
  "pages": []
}
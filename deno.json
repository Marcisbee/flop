{
  "name": "@flop/flop",
  "version": "0.1.0",
  "exports": {
    ".": "./ts/mod.ts",
    "./client": "./ts/client.ts"
  },
  "tasks": {
    "dev": "deno run --watch --allow-read --allow-write --allow-net --allow-env ts/cli.ts",
    "start": "deno run --allow-read --allow-write --allow-net --allow-env ts/cli.ts",
    "example:chat": "deno task start examples/chat/app.ts",
    "example:messages": "deno task start examples/messages/app.ts",
    "example:editor": "deno task start examples/editor/app.ts",
    "example:whiteboard": "deno task start examples/whiteboard/app.ts",
    "example:blog": "deno task start examples/blog/app.ts",
    "example:blog-go-react": "make -C examples/blog-go-react dev",
    "example:movies-go-react": "make -C examples/movies-go-react dev",
    "example:twitter-go-react": "make -C examples/twitter-go-react dev",
    "test": "deno test --allow-read --allow-write --allow-net --allow-env ts/tests/",
    "check": "deno check ts/mod.ts ts/client.ts ts/cli.ts",
    "bench": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net benchmarks/compare/run.ts",
    "bench:micro": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net benchmarks/micro/run.ts",
    "bench:clean": "deno run --allow-read --allow-write benchmarks/compare/clean.ts",
    "bench:report": "deno run --allow-net --allow-read jsr:@std/http/file-server benchmarks/compare --port=8090"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "flop": "./ts/mod.ts",
    "flop/client": "./ts/client.ts",
    "react": "npm:react@^19",
    "react-dom": "npm:react-dom@^19"
  }
}

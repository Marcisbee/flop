{
  "name": "@flop/flop",
  "version": "0.1.0",
  "exports": {
    ".": "./ts/mod.ts",
    "./client": "./ts/client.ts"
  },
  "tasks": {
    "dev": "deno run --watch --allow-read --allow-write --allow-net --allow-env ts/cli.ts",
    "start": "deno run --allow-read --allow-write --allow-net --allow-env ts/cli.ts",
    "test": "deno test --allow-read --allow-write --allow-net --allow-env ts/tests/",
    "check": "deno check ts/mod.ts ts/client.ts ts/cli.ts",
    "bench": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net benchmarks/compare/run.ts",
    "bench:compare": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net benchmarks/compare/run.ts",
    "bench:report": "deno run --allow-net --allow-read jsr:@std/http/file-server benchmarks/compare --port=8090"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "flop": "./ts/mod.ts",
    "flop/client": "./ts/client.ts",
    "react": "npm:react@^19",
    "react-dom": "npm:react-dom@^19"
  }
}
